# URL pública do site (usada nos redirects do Stripe Checkout)
NEXT_PUBLIC_SITE_URL=http://localhost:3200

# Stripe — https://dashboard.stripe.com/apikeys
# Use uma Restricted Key (rk_...) com permissão de escrita em Checkout
# Sessions e leitura de Payment Intents — só sk_ se ainda não tiver RAK
STRIPE_SECRET_KEY=

# Signing secret do endpoint de webhook (Developers → Webhooks, ou
# `stripe listen --forward-to localhost:3200/api/stripe-webhook` local)
STRIPE_WEBHOOK_SECRET=

# Sanity — preencha após criar o projeto (npm create sanity@latest)
# Sem estes valores o site usa o catálogo local de demonstração
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Neon Postgres — pedidos (schema em db/001_orders.sql)
# Connection string do projeto no console.neon.tech
DATABASE_URL=

# Painel /admin
ADMIN_PASSWORD=

# Frete: nenhuma env necessária. lib/shipping.ts resolve o estado do
# CEP via BrasilAPI (pública, sem token) e aplica tabela fixa por
# região a partir de Belém-PA — ver REGIONS em lib/shipping.ts
